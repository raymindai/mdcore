{
  "name": "@mdcore/api",
  "version": "0.1.0",
  "description": "mdfy.app API client — publish, update, pull, delete documents",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "keywords": [
    "mdfy",
    "mdcore",
    "markdown",
    "api-client",
    "publish",
    "documents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raymindai/mdcore",
    "directory": "packages/api"
  },
  "engines": {
    "node": ">=18"
  }
}
