{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/lifecycle-sweep",
      "schedule": "0 4 * * *"
    }
  ],
  "buildCommand": "cd apps/web && npm run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "cd apps/web && npm install",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Powered-By",
          "value": "mdfy.app"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.mdfy.app" }],
      "destination": "https://mdfy.app/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mdfy.cc" }],
      "destination": "https://mdfy.app/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.mdfy.cc" }],
      "destination": "https://mdfy.app/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mdcore.ai" }],
      "destination": "https://mdfy.app/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mdcore.org" }],
      "destination": "https://mdfy.app/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mdcore.md" }],
      "destination": "https://mdfy.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:id([A-Za-z0-9_-]{6,12}).md",
      "destination": "/raw/:id"
    },
    {
      "source": "/:id([A-Za-z0-9_-]{6,12}).txt",
      "destination": "/raw/:id"
    },
    {
      "source": "/:id([A-Za-z0-9_-]{6,12})",
      "has": [{ "type": "header", "key": "accept", "value": ".*text\\/(markdown|plain).*" }],
      "destination": "/raw/:id"
    },
    {
      "source": "/:id([A-Za-z0-9_-]{6,12})",
      "has": [{ "type": "header", "key": "user-agent", "value": ".*(GPTBot|ChatGPT-User|OAI-SearchBot|Claude-Web|ClaudeBot|anthropic-ai|Anthropic|Google-Extended|GoogleOther|PerplexityBot|cohere-ai|YouBot|Bytespider|Bingbot|DuckDuckBot|Applebot-Extended|MistralAI|Meta-ExternalAgent).*" }],
      "destination": "/raw/:id"
    },
    {
      "source": "/b/:id([A-Za-z0-9_-]{6,12}).md",
      "destination": "/raw/bundle/:id"
    },
    {
      "source": "/b/:id([A-Za-z0-9_-]{6,12}).txt",
      "destination": "/raw/bundle/:id"
    },
    {
      "source": "/b/:id([A-Za-z0-9_-]{6,12})",
      "has": [{ "type": "header", "key": "accept", "value": ".*text\\/(markdown|plain).*" }],
      "destination": "/raw/bundle/:id"
    },
    {
      "source": "/b/:id([A-Za-z0-9_-]{6,12})",
      "has": [{ "type": "header", "key": "user-agent", "value": ".*(GPTBot|ChatGPT-User|OAI-SearchBot|Claude-Web|ClaudeBot|anthropic-ai|Anthropic|Google-Extended|GoogleOther|PerplexityBot|cohere-ai|YouBot|Bytespider|Bingbot|DuckDuckBot|Applebot-Extended|MistralAI|Meta-ExternalAgent).*" }],
      "destination": "/raw/bundle/:id"
    },
    {
      "source": "/hub/:slug([a-z0-9_-]{3,32})/log.md",
      "destination": "/raw/hub/:slug/log.md"
    },
    {
      "source": "/hub/:slug([a-z0-9_-]{3,32})/lint.md",
      "destination": "/raw/hub/:slug/lint.md"
    },
    {
      "source": "/hub/:slug([a-z0-9_-]{3,32})/suggested-queries.md",
      "destination": "/raw/hub/:slug/suggested-queries.md"
    },
    {
      "source": "/hub/:slug([a-z0-9_-]{3,32}).md",
      "destination": "/raw/hub/:slug"
    },
    {
      "source": "/hub/:slug([a-z0-9_-]{3,32}).txt",
      "destination": "/raw/hub/:slug"
    },
    {
      "source": "/hub/:slug([a-z0-9_-]{3,32})",
      "has": [{ "type": "header", "key": "accept", "value": ".*text\\/(markdown|plain).*" }],
      "destination": "/raw/hub/:slug"
    },
    {
      "source": "/hub/:slug([a-z0-9_-]{3,32})",
      "has": [{ "type": "header", "key": "user-agent", "value": ".*(GPTBot|ChatGPT-User|OAI-SearchBot|Claude-Web|ClaudeBot|anthropic-ai|Anthropic|Google-Extended|GoogleOther|PerplexityBot|cohere-ai|YouBot|Bytespider|Bingbot|DuckDuckBot|Applebot-Extended|MistralAI|Meta-ExternalAgent).*" }],
      "destination": "/raw/hub/:slug"
    },
    {
      "source": "/:id([A-Za-z0-9_-]{6,12})",
      "has": [{ "type": "header", "key": "sec-fetch-dest", "value": "document" }],
      "destination": "/d/:id"
    },
    {
      "source": "/:id([A-Za-z0-9_-]{6,12})",
      "destination": "/api/docs/:id"
    }
  ]
}
