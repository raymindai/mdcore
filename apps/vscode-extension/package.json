{
  "name": "mdfy-vscode",
  "displayName": "mdfy.app — Markdown Publisher",
  "description": "WYSIWYG preview and publish Markdown documents to mdfy.app with bidirectional cloud sync. Beautiful rendering with GFM, KaTeX math, Mermaid diagrams, and code highlighting.",
  "version": "1.3.0",
  "publisher": "raymindai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raymindai/mdcore"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#09090b",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Formatters"
  ],
  "keywords": [
    "markdown",
    "preview",
    "publish",
    "mdfy",
    "mermaid",
    "katex",
    "gfm",
    "wysiwyg",
    "sync"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onView:mdfyDocuments"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mdfy",
          "title": "mdfy.app",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "mdfy": [
        {
          "id": "mdfyDocuments",
          "name": "Documents",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "mdfy.preview",
        "title": "mdfy: Preview (WYSIWYG)",
        "icon": {
          "dark": "media/icon-dark.svg",
          "light": "media/icon-light.svg"
        }
      },
      {
        "command": "mdfy.publish",
        "title": "mdfy: Publish to mdfy.app",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "mdfy.update",
        "title": "mdfy: Push to mdfy.app",
        "icon": "$(arrow-up)"
      },
      {
        "command": "mdfy.pull",
        "title": "mdfy: Pull from mdfy.app",
        "icon": "$(arrow-down)"
      },
      {
        "command": "mdfy.login",
        "title": "mdfy: Login to mdfy.app",
        "icon": "$(sign-in)"
      },
      {
        "command": "mdfy.sync",
        "title": "mdfy: Sync Status",
        "icon": "$(sync)"
      },
      {
        "command": "mdfy.export",
        "title": "mdfy: Export",
        "icon": "$(export)"
      },
      {
        "command": "mdfy.sidebar.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "mdfy.aiPolish",
        "title": "mdfy: AI Polish",
        "icon": "$(sparkle)"
      },
      {
        "command": "mdfy.aiSummary",
        "title": "mdfy: AI Summary",
        "icon": "$(output)"
      },
      {
        "command": "mdfy.aiTldr",
        "title": "mdfy: AI TL;DR",
        "icon": "$(note)"
      },
      {
        "command": "mdfy.aiTranslate",
        "title": "mdfy: AI Translate",
        "icon": "$(globe)"
      },
      {
        "command": "mdfy.aiChat",
        "title": "mdfy: Ask AI to Edit",
        "icon": "$(comment-discussion)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mdfy.preview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "mdfy.publish",
          "when": "editorLangId == markdown",
          "group": "mdfy@1"
        },
        {
          "command": "mdfy.update",
          "when": "editorLangId == markdown",
          "group": "mdfy@2"
        },
        {
          "command": "mdfy.pull",
          "when": "editorLangId == markdown",
          "group": "mdfy@3"
        },
        {
          "command": "mdfy.export",
          "when": "editorLangId == markdown",
          "group": "mdfy@4"
        },
        {
          "command": "mdfy.aiPolish",
          "when": "editorLangId == markdown",
          "group": "mdfy@5"
        },
        {
          "command": "mdfy.aiSummary",
          "when": "editorLangId == markdown",
          "group": "mdfy@6"
        },
        {
          "command": "mdfy.aiTldr",
          "when": "editorLangId == markdown",
          "group": "mdfy@7"
        },
        {
          "command": "mdfy.aiTranslate",
          "when": "editorLangId == markdown",
          "group": "mdfy@8"
        },
        {
          "command": "mdfy.aiChat",
          "when": "editorLangId == markdown",
          "group": "mdfy@9"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mdfy.preview",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "editorLangId == markdown"
      },
      {
        "command": "mdfy.publish",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorLangId == markdown"
      },
      {
        "command": "mdfy.export",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorLangId == markdown"
      }
    ],
    "configuration": {
      "title": "mdfy.app",
      "properties": {
        "mdfy.apiBaseUrl": {
          "type": "string",
          "default": "https://mdfy.app",
          "description": "Base URL for the mdfy.app API"
        },
        "mdfy.theme": {
          "type": "string",
          "enum": [
            "auto",
            "dark",
            "light"
          ],
          "default": "auto",
          "description": "Preview theme. 'auto' follows VS Code's color theme."
        },
        "mdfy.autoSync": {
          "type": "boolean",
          "default": false,
          "description": "Automatically sync published documents on save"
        },
        "mdfy.autoPreview": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open mdfy preview when opening a Markdown file"
        },
        "mdfy.syncInterval": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "maximum": 300,
          "description": "Sync polling interval in seconds (when autoSync is enabled)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "yjs": "^13.6.30"
  }
}
