{
  "name": "mdfy-desktop",
  "version": "0.1.0",
  "description": "mdfy for Mac — Figma for Markdown",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "cc.mdfy.desktop",
    "productName": "mdfy",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "role": "Editor"
      }
    ]
  }
}
