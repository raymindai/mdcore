{
  "name": "mdfy-desktop",
  "version": "1.0.0",
  "description": "mdfy for Mac — Markdown publishing with native file integration",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:dmg": "electron-builder --mac dmg",
    "build:mas": "electron-builder --mac mas",
    "build:all": "electron-builder --mac dmg mas",
    "build:universal": "electron-builder --mac --universal"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "cc.mdfy.desktop",
    "productName": "mdfy",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "mime-types.js",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../quicklook/MdfyQuickLook/build/MdfyQuickLook.app",
        "to": "MdfyQuickLook.app"
      }
    ],
    "protocols": [
      {
        "name": "mdfy",
        "schemes": ["mdfy"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png",
      "darkModeSupport": true,
      "target": [
        { "target": "dmg", "arch": ["universal"] }
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": false
    },
    "mas": {
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "hardenedRuntime": false,
      "type": "distribution"
    },
    "dmg": {
      "title": "mdfy",
      "icon": "assets/icon.png",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "mdown",
        "name": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "mkd",
        "name": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "txt",
        "name": "Text Document",
        "role": "Editor"
      },
      {
        "ext": "pdf",
        "name": "PDF Document",
        "role": "Viewer"
      },
      {
        "ext": "docx",
        "name": "Word Document",
        "role": "Viewer"
      },
      {
        "ext": "pptx",
        "name": "PowerPoint Presentation",
        "role": "Viewer"
      },
      {
        "ext": "xlsx",
        "name": "Excel Spreadsheet",
        "role": "Viewer"
      },
      {
        "ext": "html",
        "name": "HTML Document",
        "role": "Viewer"
      },
      {
        "ext": "csv",
        "name": "CSV File",
        "role": "Viewer"
      },
      {
        "ext": "json",
        "name": "JSON File",
        "role": "Viewer"
      }
    ]
  }
}
